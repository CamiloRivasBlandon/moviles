<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    tools:context=".Menu">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bienvenido a tus Herramientas"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnIrAgenda"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="24dp"
        android:onClick="abrirAgenda"
        android:text="Abrir Agenda"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:backgroundTint="@color/naranja" />

    <Button
        android:id="@+id/btnIrCalculadora"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="24dp"
        android:onClick="abrirCalculadora"
        android:text="Abrir Calculadora"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:backgroundTint="@color/naranja" />

    <Button
        android:id="@+id/btnCerrarSesion"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="24dp"
        android:text="Cerrar Sesion"
        android:textSize="18sp"
        android:onClick="cerrarSesion"
        app:backgroundTint="@color/naranja"
        android:textColor="@color/white" />
</LinearLayout>